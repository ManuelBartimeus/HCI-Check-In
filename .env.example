# ─────────────────────────────────────────────
#  Church Attendance .env.example
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── Flask ─────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-key
FLASK_ENV=development
FLASK_DEBUG=1

# ── Database ──────────────────────────────────
# SQLite (development default)
DATABASE_URL=sqlite:///church_attendance.db
# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/church_attendance

# ── JWT ───────────────────────────────────────
JWT_SECRET_KEY=change-me-to-another-random-secret

# ── Admin Credentials ─────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=passw0rd

# ── Church Config ─────────────────────────────
CHURCH_NAME=Harvest Chapel KNUST
CHURCH_TIMEZONE=Africa/Accra

# ── CORS ──────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Rate Limiting ─────────────────────────────
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_CHECKIN=10 per minute
